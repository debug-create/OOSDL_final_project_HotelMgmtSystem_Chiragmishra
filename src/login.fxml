<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="LoginController"
           prefWidth="1100" prefHeight="740"
           style="-fx-background-color: linear-gradient(from 0% 0% to 100% 100%, #1a1a1a, #2d1f0e);">

    <!-- Centered Login Card -->
    <VBox fx:id="loginCard"
          alignment="CENTER"
          spacing="8"
          maxWidth="450"
          style="-fx-background-color: #1f190e;
                 -fx-border-color: #c8963e;
                 -fx-border-width: 1.5;
                 -fx-border-radius: 10;
                 -fx-background-radius: 10;
                 -fx-effect: dropshadow(gaussian, #c8963e44, 40, 0.1, 0, 0);">
        <padding>
            <Insets top="56" right="60" bottom="56" left="60"/>
        </padding>

        <!-- Hotel Brand -->
        <Label text="LUMIÈRE"
               style="-fx-font-family: 'Georgia';
                      -fx-font-size: 54;
                      -fx-font-weight: bold;
                      -fx-text-fill: #c8963e;"/>

        <Label text="HOTEL MANAGEMENT SYSTEM"
               style="-fx-font-family: 'Courier New';
                      -fx-font-size: 11;
                      -fx-text-fill: #888880;
                      -fx-letter-spacing: 2;"/>

        <!-- Divider -->
        <Separator style="-fx-background-color: #c8963e44; -fx-opacity: 0.6;">
            <VBox.margin><Insets top="22" bottom="22"/></VBox.margin>
        </Separator>

        <!-- Welcome Text -->
        <Label text="STAFF LOGIN"
               style="-fx-font-family: 'Georgia';
                      -fx-font-size: 20;
                      -fx-font-weight: bold;
                      -fx-text-fill: #f0ead6;"/>

        <Label text="Enter your credentials to access the system"
               style="-fx-font-family: 'Courier New';
                      -fx-font-size: 11;
                      -fx-text-fill: #888880;">
            <VBox.margin><Insets bottom="14"/></VBox.margin>
        </Label>

        <!-- Name Input -->
        <TextField fx:id="tfStaffName"
                   promptText="Staff name (e.g. Chirag)"
                   maxWidth="340"
                   style="-fx-background-color: #2a2a2a;
                          -fx-text-fill: #f0ead6;
                          -fx-prompt-text-fill: #666660;
                          -fx-border-color: #383830;
                          -fx-border-radius: 4;
                          -fx-background-radius: 4;
                          -fx-padding: 13 16 13 16;
                          -fx-font-size: 14px;
                          -fx-font-family: 'Segoe UI';">
            <VBox.margin><Insets bottom="6"/></VBox.margin>
        </TextField>

        <!-- Password Input -->
        <PasswordField fx:id="pfPassword"
                       promptText="Password"
                       maxWidth="340"
                       style="-fx-background-color: #2a2a2a;
                              -fx-text-fill: #f0ead6;
                              -fx-prompt-text-fill: #666660;
                              -fx-border-color: #383830;
                              -fx-border-radius: 4;
                              -fx-background-radius: 4;
                              -fx-padding: 13 16 13 16;
                              -fx-font-size: 14px;
                              -fx-font-family: 'Segoe UI';">
            <VBox.margin><Insets bottom="6"/></VBox.margin>
        </PasswordField>

        <!-- Error Label -->
        <Label fx:id="lblError"
               text=""
               maxWidth="340"
               style="-fx-text-fill: #e05252;
                      -fx-font-size: 11;
                      -fx-font-family: 'Courier New';">
            <VBox.margin><Insets bottom="8"/></VBox.margin>
        </Label>

        <!-- Enter Button -->
        <Button fx:id="btnEnter"
                text="ENTER THE SYSTEM"
                maxWidth="340"
                defaultButton="true"
                onAction="#handleEnter"
                style="-fx-background-color: #c8963e;
                       -fx-text-fill: #1a1200;
                       -fx-font-weight: bold;
                       -fx-font-size: 13px;
                       -fx-font-family: 'Segoe UI';
                       -fx-padding: 13 32 13 32;
                       -fx-background-radius: 4;
                       -fx-cursor: hand;">
        </Button>

        <!-- Footer -->
        <HBox alignment="CENTER">
            <VBox.margin><Insets top="36"/></VBox.margin>
            <Label text="Password: admin123  •  LUMIÈRE  •  2025"
                   style="-fx-font-family: 'Courier New';
                          -fx-font-size: 9;
                          -fx-text-fill: #4a4440;"/>
        </HBox>
    </VBox>

</StackPane>
